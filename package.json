    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prebuild": "yarn run lint",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "build:icons": "tsx src/assets/iconify-icons/bundle-icons-css.ts",
    "postinstall": "yarn run build:icons && yarn prisma generate",
    "db:update": "npx prisma db push",
    "db:seed": "npx prisma db seed --",
    "db:init": "yarn run db:update && yarn run db:seed",
    "data:migration": "tsx data/migration/script.ts"
  },
